{
  "manifest_version": 3,
  "name": "Edge Command Panel",
  "description": "Open a VS Code-like command panel to search tabs, bookmarks, commands, and custom URL mappings.",
  "version": "0.2.0",
  "permissions": ["tabs", "scripting", "bookmarks", "favicon", "storage"],
  "action": {
    "default_title": "Open tab command panel"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "options_page": "options/options.html",
  "commands": {
    "toggle-command-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open tab command panel"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/vendor/pinyin-pro.js", "src/pinyin.js", "src/content.js"],
      "css": ["src/panel.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["_favicon/*"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
